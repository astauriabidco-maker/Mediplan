# Mediplan - exemple d'environnement preproduction
# Copier vers .env.preprod, remplacer les secrets, puis lancer les scripts preprod.

# --- RUNTIME ---
NODE_ENV=preproduction
DB_SYNCHRONIZE=false
PORT=3005
JSON_BODY_LIMIT=25mb
COUNTRY_CODE=FR
FRONTEND_URL=http://localhost:5175

# --- DATABASE COMPOSE ---
# En compose, le backend joint Postgres via le nom du service.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nestuser
POSTGRES_PASSWORD=CHANGE_ME_PREPROD_DB_PASSWORD
POSTGRES_DB=mediplan_preprod

# Port publie sur la machine hote.
POSTGRES_PUBLIC_PORT=5441

# --- CACHE ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PUBLIC_PORT=6380

# --- SECURITY ---
# Minimum recommande: 64 caracteres aleatoires.
JWT_SECRET=CHANGE_ME_WITH_A_64_CHAR_RANDOM_SECRET_FOR_PREPROD_ONLY_00000000

# --- AI & INTEGRATIONS ---
MISTRAL_API_KEY=dummy
WHATSAPP_API_TOKEN=dummy
META_ACCESS_TOKEN=dummy
WHATSAPP_PHONE_ID=dummy
META_PHONE_ID=dummy
WHATSAPP_VERIFY_TOKEN=mediplan_preprod_verify_token

# --- SMOKE API ---
BASE_URL=http://localhost:3005
TENANT_ID=HGD-DOUALA
SMOKE_EMAIL=superadmin@mediplan.demo
SMOKE_PASSWORD=password123
SMOKE_REQUIRE_AUTH=true
REPORT_DIR=preprod-reports

# --- OPS NOTIFICATIONS ---
# Defaults are dry-run only. Enable preprod channels deliberately.
# OPS_NOTIFICATION_HIGH_CHANNELS=LOG,WEBHOOK
# OPS_NOTIFICATION_CRITICAL_CHANNELS=LOG,WEBHOOK,SLACK,TEAMS
# OPS_NOTIFICATION_TENANT_HGD_DOUALA_CRITICAL_CHANNELS=LOG,WEBHOOK,SLACK
# OPS_NOTIFICATION_HIGH_RECIPIENT_ROLES=OPS,MANAGER
# OPS_NOTIFICATION_CRITICAL_RECIPIENT_ROLES=OPS,MANAGER,ON_CALL
# OPS_NOTIFICATION_RECIPIENTS_OPS=ops-preprod@mediplan.test
# OPS_NOTIFICATION_TENANT_HGD_DOUALA_RECIPIENTS_ON_CALL=astreinte-hgd-preprod@mediplan.test
# OPS_NOTIFICATION_HIGH_DEDUPE_WINDOW_MS=300000
# OPS_NOTIFICATION_HIGH_REPEAT_DELAY_MS=1800000
# OPS_NOTIFICATION_CRITICAL_DEDUPE_WINDOW_MS=60000
# OPS_NOTIFICATION_CRITICAL_REPEAT_DELAY_MS=600000
# OPS_NOTIFICATION_WEBHOOK_URL=https://example.invalid/ops-webhook
# OPS_NOTIFICATION_SLACK_WEBHOOK_URL=https://example.invalid/slack-webhook
# OPS_NOTIFICATION_TEAMS_WEBHOOK_URL=https://example.invalid/teams-webhook
# OPS_NOTIFICATION_TOKEN=CHANGE_ME_PREPROD_OPS_NOTIFICATION_BEARER_TOKEN
