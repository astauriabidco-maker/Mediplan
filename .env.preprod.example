# Mediplan - exemple d'environnement preproduction
# Copier vers .env.preprod, remplacer les secrets, puis lancer les scripts preprod.

# --- RUNTIME ---
NODE_ENV=preproduction
DB_SYNCHRONIZE=false
PORT=3005
COUNTRY_CODE=FR
FRONTEND_URL=http://localhost:5175

# --- DATABASE COMPOSE ---
# En compose, le backend joint Postgres via le nom du service.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nestuser
POSTGRES_PASSWORD=CHANGE_ME_PREPROD_DB_PASSWORD
POSTGRES_DB=mediplan_preprod

# Port publie sur la machine hote.
POSTGRES_PUBLIC_PORT=5441

# --- CACHE ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PUBLIC_PORT=6380

# --- SECURITY ---
# Minimum recommande: 64 caracteres aleatoires.
JWT_SECRET=CHANGE_ME_WITH_A_64_CHAR_RANDOM_SECRET_FOR_PREPROD_ONLY_00000000

# --- AI & INTEGRATIONS ---
MISTRAL_API_KEY=dummy
WHATSAPP_API_TOKEN=dummy
META_ACCESS_TOKEN=dummy
WHATSAPP_PHONE_ID=dummy
META_PHONE_ID=dummy
WHATSAPP_VERIFY_TOKEN=mediplan_preprod_verify_token

# --- SMOKE API ---
BASE_URL=http://localhost:3005
TENANT_ID=HGD-DOUALA
SMOKE_EMAIL=superadmin@mediplan.demo
SMOKE_PASSWORD=password123
SMOKE_REQUIRE_AUTH=true
REPORT_DIR=preprod-reports
