# Mediplan - modele ENV_FILE production client
# Copier hors depot ou vers un emplacement ignore localement, puis remplacer
# chaque valeur CHANGE_ME par la valeur client reelle fournie par l'exploitation.
# Ne pas committer de fichier .env.prod-client contenant des secrets reels.

# --- RUNTIME ---
NODE_ENV=production
DB_SYNCHRONIZE=false
PORT=3000
COUNTRY_CODE=FR

# --- NETWORK ---
FRONTEND_URL=https://CHANGE_ME_CLIENT_FRONTEND_HOST
BASE_URL=https://CHANGE_ME_CLIENT_API_HOST

# --- DATABASE ---
POSTGRES_HOST=CHANGE_ME_POSTGRES_HOST
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME_POSTGRES_USER
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=CHANGE_ME_POSTGRES_DB

# --- SECURITY ---
# Minimum requis par le smoke strict: 64 caracteres ou plus.
JWT_SECRET=CHANGE_ME_WITH_CLIENT_64_CHAR_MIN_RANDOM_SECRET_NOT_IN_REPO_000000

# --- OPTIONAL AI ---
# Renseigner uniquement si l'option Mistral est activee pour ce client.
# MISTRAL_API_KEY=CHANGE_ME_MISTRAL_API_KEY
