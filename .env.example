# Mediplan - Environment Settings Example

# --- DATABASE ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nestuser
POSTGRES_PASSWORD=nestpassword
POSTGRES_DB=nestdb

# --- CACHE ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- SECURITY ---
# A strong 64-character secret minimum for production. Do NOT leak this.
JWT_SECRET=YOUR_VERY_STRONG_JWT_SECRET_HERE

# --- NETWORK ---
# The URL of the frontend in production, used to configure CORS.
FRONTEND_URL=https://app.mediplan.cm

# --- LOCALIZATION ---
COUNTRY_CODE=CM

# --- WHATSAPP API (Meta) ---
WHATSAPP_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
META_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_PHONE_ID=123456789012345
META_PHONE_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=mediplan_secure_token

# --- AI & INSIGHT ENGINE ---
# Optional: Requires a Mistral API key for dynamic NLP dashboard queries.
MISTRAL_API_KEY=your_mistral_api_key_here
