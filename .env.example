# Mediplan - Environment Settings Example

# --- DATABASE ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nestuser
POSTGRES_PASSWORD=nestpassword
POSTGRES_DB=nestdb

# --- CACHE ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- SECURITY ---
# A strong 64-character secret minimum for production. Do NOT leak this.
JWT_SECRET=YOUR_VERY_STRONG_JWT_SECRET_HERE

# --- NETWORK ---
# The URL of the frontend in production, used to configure CORS.
FRONTEND_URL=https://app.mediplan.cm

# --- LOCALIZATION ---
COUNTRY_CODE=CM

# --- WHATSAPP API (Meta) ---
WHATSAPP_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
META_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_PHONE_ID=123456789012345
META_PHONE_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=mediplan_secure_token

# --- AI & INSIGHT ENGINE ---
# Optional: Requires a Mistral API key for dynamic NLP dashboard queries.
MISTRAL_API_KEY=your_mistral_api_key_here

# --- OPS NOTIFICATIONS ---
# Defaults are dry-run only. Configure severity and tenant overrides explicitly.
# OPS_NOTIFICATION_HIGH_CHANNELS=LOG,WEBHOOK
# OPS_NOTIFICATION_CRITICAL_CHANNELS=LOG,WEBHOOK,SLACK,TEAMS
# OPS_NOTIFICATION_TENANT_HGD_DOUALA_CRITICAL_CHANNELS=LOG,WEBHOOK,SLACK
# OPS_NOTIFICATION_HIGH_RECIPIENT_ROLES=OPS,MANAGER
# OPS_NOTIFICATION_CRITICAL_RECIPIENT_ROLES=OPS,MANAGER,ON_CALL
# OPS_NOTIFICATION_RECIPIENTS_OPS=ops@mediplan.cm
# OPS_NOTIFICATION_TENANT_HGD_DOUALA_RECIPIENTS_ON_CALL=astreinte-hgd@mediplan.cm
# OPS_NOTIFICATION_HIGH_DEDUPE_WINDOW_MS=300000
# OPS_NOTIFICATION_HIGH_REPEAT_DELAY_MS=1800000
# OPS_NOTIFICATION_CRITICAL_DEDUPE_WINDOW_MS=60000
# OPS_NOTIFICATION_CRITICAL_REPEAT_DELAY_MS=600000
# OPS_NOTIFICATION_WEBHOOK_URL=https://example.invalid/ops-webhook
# OPS_NOTIFICATION_SLACK_WEBHOOK_URL=https://example.invalid/slack-webhook
# OPS_NOTIFICATION_TEAMS_WEBHOOK_URL=https://example.invalid/teams-webhook
# OPS_NOTIFICATION_TOKEN=CHANGE_ME_OPS_NOTIFICATION_BEARER_TOKEN
